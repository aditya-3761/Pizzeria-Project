# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── MONGODB ──
# Local:  mongodb://localhost:27017/pizzeria
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/pizzeria
MONGO_URI=mongodb://localhost:27017/pizzeria

# ── JWT ──
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ── RAZORPAY ──
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=YourKeySecretHere

# ── EMAIL (for forgot password) ──
# Gmail: enable "Less secure app access" OR use App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Pizzeria <noreply@pizzeria.com>

# ── FRONTEND URL (for CORS) ──
FRONTEND_URL=http://127.0.0.1:5500

# ── ADMIN ──
ADMIN_PASSWORD=6870
